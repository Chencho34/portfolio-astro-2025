---
import "../styles/global.css"
import '@fontsource-variable/outfit'
import '@fontsource-variable/ibm-plex-sans'

import { BaseHead, Nav } from '../components/ui'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title?: string
  description?: string
  slug: string
}

const {
  title = 'Portfolio',
  description = 'My personal portfolio',
  slug //TODO: Dinamic image preview metadata 
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
  </head>

  <body class="bg-base text-ink antialiased">
    <Nav />
    <main style="padding-top: var(--nav-height);">
      <slot />
    </main>
  </body>
</html>

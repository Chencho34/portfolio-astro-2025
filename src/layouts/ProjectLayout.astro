---
import { ClientRouter } from "astro:transitions";
import { BaseHead, Container, Footer } from "../components/ui";
import "../styles/global.css";
import { Contact } from "../components/sections";

interface Props {
  title: string;
  slug: string;
  description: string;
}
const { title, slug, description } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
  </head>
  <body>
    <!-- NAV específico de proyecto -->
    <header
      class="fixed top-0 inset-x-0 z-50 border-b border-line"
      style="background:rgba(10,10,10,0.9);backdrop-filter:blur(16px)"
    >
      <nav
        class="max-w-5xl mx-auto px-8 h-14 flex items-center justify-between"
      >
        <!-- breadcrumb -->
        <div class="flex items-center gap-3">
          <a
            href="/#projects"
            class="inline-flex items-center gap-2 font-mono text-xs text-faint hover:text-muted transition-colors tracking-wider"
          >
            <svg
              class="w-3.5 h-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path d="M19 12H5M12 5l-7 7 7 7"></path>
            </svg>
            Proyectos
          </a>
          <span class="text-faint">/</span>
          <span class="font-mono text-xs text-muted tracking-wider">{slug}</span
          >
        </div>

        <!-- logo -->
        <a
          href="/"
          class="font-mono text-sm font-medium tracking-widest text-muted"
        >
          chencho<span class="text-lime">34</span>
        </a>
      </nav>
    </header>

    <slot />
    <Container>
      <Contact />
    </Container>
  </body>
  <Footer />
</html>

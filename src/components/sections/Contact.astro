---
import { ArrowRightIcon, DownloadIcon, ExternalLinkIcon } from "../icons/contact";
import { Section, CtaButton, PulseDot } from "../ui";
---

<Section id="contact">
  <article class="text-center mb-12">
    <p class="font-mono text-xs tracking-widest text-muted uppercase mb-5">
      Basado en Veracruz, Mexico — Disponible remotamente
    </p>
    <h2 class="font-bold leading-none tracking-tighter select-none" style="font-size:clamp(3.5rem,12vw,8rem)">
      <span class="text-ink">Chencho</span>
      <span style="color:transparent;-webkit-text-stroke:1px #aadd55">34</span>
    </h2>
    <a
      href="mailto:armandocrescencio343@gmail.com"
      class="group inline-flex items-center gap-2 mt-5 text-muted hover:text-lime transition-colors"
    >
      <span class="font-mono text-sm tracking-wide">armandocrescencio343@gmail.com</span>
      <ExternalLinkIcon class:list="stroke-2 size-4 opacity-0 group-hover:opacity-100 -translate-y-0.5 group-hover:translate-y-0 transition-all"/>
    </a>
  </article>
  <article class="border border-line bg-surface rounded-xl p-5 mb-12 flex flex-col sm:flex-row items-center justify-between gap-5">
    <section class="flex items-center gap-3">
      <PulseDot />
      <div>
        <p class="text-sm font-medium text-ink">Disponible para proyectos</p>
        <p class="text-xs text-muted font-light">
          Freelance &bull; Tiempo completo &bull; Remoto
        </p>
      </div>
    </section>
    <div class="hidden sm:block w-px h-10 bg-line2"></div>
    <section class="flex gap-2.5 flex-wrap justify-center">
      <CtaButton
        variant="primary"
        href="mailto:armandocrescencio343@gmail.com"
      >
        Hablemos
        <ArrowRightIcon class:list="size-3.5" />
      </CtaButton>
      <CtaButton
        variant="ghost"
        download
        href="/ArmandoCrescencio_CV26.pdf"
      >
        Descargar CV
        <DownloadIcon class:list="size-3.5"/>
      </CtaButton>
    </section>
  </article>
</Section>
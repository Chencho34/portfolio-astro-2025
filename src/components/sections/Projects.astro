---
import { getCollection } from "astro:content";
import { Section, TitleSection, CardProject, SubtitleSection } from "../../components/ui";
import FeaturedProject from "../../components/ui/FeaturedProject.astro";

const allProjects = await getCollection('projects')

// ── 2. Sort by date descending ────────────────────────────────
const sorted = allProjects.sort((a, b) => {
  const aDate = a.data.date?.getTime() ?? 0;
  const bDate = b.data.date?.getTime() ?? 0;
  return bDate - aDate;
});

// ── 3. Split groups ───────────────────────────────────────────
const featuredProjects = sorted.filter(p => p.data.featured);
const otherProjects = sorted.filter(p => !p.data.featured);
---

<Section
  id="projects"
  ariaLabelledby="projects-heading"
>
  <header class="mb-10 md:mb-14">
    <TitleSection id="projects-heading" title="Projects"/>
  </header>

  {featuredProjects.length > 0 && (
    <div class="space-y-4 mb-8">
      {featuredProjects.map((project, featuredIndex) => (
        <FeaturedProject
          project={project}
          featuredIndex={featuredIndex}
        />
      ))}
    </div>
  )}

  {otherProjects.length > 0 && (
    <SubtitleSection title="Otros Projectos" />
    <div class="space-y-4 list-none" role="list" aria-label="Other projects">
      {otherProjects.map(project => (
        <div>
          <CardProject project={project} />
        </div>
      ))}
    </div>
  )}

  {allProjects.length === 0 && (
    <div class="flex items-center justify-center py-20">
      <p class="font-mono text-sm text-white/20">No projects yet.</p>
    </div>
  )}
</Section>
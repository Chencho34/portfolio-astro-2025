---
interface Props {
  githubUrl?: string
  demoUrl?:   string
  variant?:   'row' | 'column'
}

const { githubUrl, demoUrl, variant = 'row' } = Astro.props

const hasLinks = githubUrl || demoUrl
---

{hasLinks && (
  <div
    class:list={[
      'mb-5 animate-fade-up',
      variant === 'row'    && 'flex flex-wrap gap-2',
      variant === 'column' && 'flex flex-col gap-2',
    ]}
    style="animation-delay: 0.15s;"
  >
    {demoUrl && (
      <a
        href={demoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex items-center gap-2 rounded-md text-xs font-mono font-medium transition-all duration-200',
          'hover:opacity-90 active:scale-95',
          variant === 'column' && 'justify-center',
        ]}
        style="
          background: var(--color-lime);
          color: #0a0a0a;
          padding: 7px 16px;
        "
      >
        <!-- External link icon -->
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 10L10 1M10 1H4M10 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        live demo
      </a>
    )}

    {githubUrl && (
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex items-center gap-2 rounded-md text-xs font-mono transition-all duration-200',
          'hover:border-line hover:text-ink active:scale-95',
          variant === 'column' && 'justify-center',
        ]}
        style="
          background: var(--color-surface2);
          border: 1px solid var(--color-line2);
          color: var(--color-ink);
          padding: 7px 16px;
        "
      >
        <!-- GitHub icon -->
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 0.5C3.18 0.5 0.5 3.18 0.5 6.5C0.5 9.16 2.22 11.42 4.64 12.22C4.94 12.27 5.05 12.09 5.05 11.93V10.91C3.37 11.27 3.02 10.14 3.02 10.14C2.75 9.44 2.35 9.26 2.35 9.26C1.79 8.88 2.39 8.89 2.39 8.89C3.01 8.93 3.34 9.54 3.34 9.54C3.89 10.49 4.79 10.21 5.07 10.04C5.12 9.64 5.28 9.37 5.46 9.21C4.17 9.05 2.81 8.54 2.81 6.33C2.81 5.67 3.04 5.12 3.36 4.69C3.31 4.53 3.1 3.9 3.41 3.05C3.41 3.05 3.93 2.88 5.05 3.68C5.52 3.55 6.01 3.48 6.5 3.48C6.99 3.48 7.48 3.55 7.95 3.68C9.07 2.88 9.59 3.05 9.59 3.05C9.9 3.9 9.69 4.53 9.64 4.69C9.96 5.12 10.19 5.67 10.19 6.33C10.19 8.55 8.82 9.04 7.53 9.2C7.75 9.39 7.95 9.77 7.95 10.36V11.93C7.95 12.09 8.06 12.28 8.37 12.22C10.79 11.42 12.5 9.16 12.5 6.5C12.5 3.18 9.82 0.5 6.5 0.5Z" fill="currentColor"/>
        </svg>
        view on github
      </a>
    )}
  </div>
)}

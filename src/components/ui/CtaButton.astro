---
import { twMerge } from 'tailwind-merge'

interface Props {
  href: string
  variant?: 'primary' | 'solid' | 'ghost' | 'outline-sm' | 'text'
  target?: '_blank' | '_self' | "_parent"
  download?: boolean
  ariaLabel?: string
  className?: string
  rel?: string
}

const { href, variant = 'ghost', target = '_self', download, ariaLabel, className, rel } = Astro.props

const styles = {
  primary: "bg-lime text-base font-semibold px-5 py-2.5 rounded-lg hover:opacity-85",
  solid: "bg-ink text-base font-semibold px-5 py-2.5 rounded-lg hover:bg-white",
  ghost: "border border-line2 text-muted font-medium px-5 py-2.5 rounded-lg hover:border-muted hover:text-ink",
  'outline-sm': "font-mono text-xs border border-lime px-3 py-1.5 rounded-md hover:bg-lime hover:text-base tracking-wider",
  text: "font-mono text-xs hover:text-lime transition-colors tracking-wider"
}

const computedRel = target === "_blank" ? rel ?? "noopener noreferrer" : rel;
---

<a
  class={
    twMerge(`inline-flex items-center gap-1.5 text-sm transition-all 
    ${styles[variant]} 
    ${className}`)
  }
  href={href}
  target={target}
  rel={computedRel}
  download={download || undefined}
  aria-label={ariaLabel}
>
  <slot />
</a>
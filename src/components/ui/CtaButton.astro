---
interface Props {
  href: string
  variant?: 'primary' | 'solid' | 'ghost' | 'outline-sm'
  target?: '_blank' | '_self'
  download?: boolean
}

const { href, variant = 'ghost', target = '_self', download } = Astro.props

const styles = {
  primary: "bg-lime text-base font-semibold px-5 py-2.5 rounded-lg hover:opacity-85",
  solid: "bg-ink text-base font-semibold px-5 py-2.5 rounded-lg hover:bg-white",
  ghost: "border border-line2 text-muted font-medium px-5 py-2.5 rounded-lg hover:border-muted hover:text-ink",
  'outline-sm':"font-mono text-xs border border-lime text-lime px-3 py-1.5 rounded-md hover:bg-lime hover:text-base tracking-wider",
}
---

<a
  href={href}
  target={target}
  download={download}
  class=`inline-flex items-center gap-1.5 text-sm transition-all ${styles[variant]}`
>
  <slot />
</a>
---
interface Props {
  number: '01' | '02' | '03' | '04'
  title: string
}
const { number, title } = Astro.props
---

<div class="flex items-center gap-4 mb-16">
  <span class="font-mono text-xs tracking-widest text-lime uppercase">
    {number}
  </span>
  <span class="h-px flex-1 bg-line2"></span>
  <h2 class="font-bold text-2xl tracking-tight">{title}</h2>
  <span class="h-px flex-1 bg-line2"></span>
</div>
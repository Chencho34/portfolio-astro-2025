---
import type { CollectionEntry } from 'astro:content';
import StatusPill from './StatusPill.astro';
import Badge from './Badge.astro';
import CtaButton from './CtaButton.astro';
import GithubIcon from '../icons/tecnologies/GithubIcon.astro';

interface Props {
  project:        CollectionEntry<'projects'>;
  featuredIndex:  number;  // Index within featured array only — drives alternation
}

const { project, featuredIndex } = Astro.props;
const { title, description, image, technologies, demoUrl, githubUrl, type } = project.data;

// true  → image left  (col 1), content right (col 2)
// false → image right (col 2), content left  (col 1)
const imageLeft = featuredIndex % 2 === 0;

const PLACEHOLDER = `https://placehold.co/960x600/1a1a1a/444?text=${encodeURIComponent(title)}`;
const primaryLink = demoUrl ?? githubUrl;
---
<article
  class="group bg-surface grid grid-cols-1 md:grid-cols-2 bg-ba rounded-xl overflow-hidden border border-white/6 hover:border-white/12 transition-colors duration-300"
  aria-label={`Featured project: ${title}`}
>
  <figure
    class:list={[
      'relative overflow-hidden bg-black aspect-16/10 md:aspect-auto',
      // Mobile: always rendered first in DOM → visually on top
      'order-first',
      // Desktop: flip position based on index
      imageLeft ? 'md:order-1' : 'md:order-2',
    ]}
  >
    <img
      src={image ?? PLACEHOLDER}
      alt={`Screenshot of ${title}`}
      class="w-full h-full object-cover object-top-left transition-transform duration-700 group-hover:scale-[1.04]"
      loading="lazy"
      decoding="async"
      width="960"
      height="600"
    />

    {type && (    
      <span
        class="absolute top-3 left-3 font-mono text-[10px] tracking-widest uppercase px-2 py-1 rounded bg-black/70 backdrop-blur-sm text-white/60 border border-white/10"
        aria-label={`Type: ${type}`}
      >
        {type}
      </span>
    )}
  </figure>

  <div
    class:list={[
      'flex flex-col justify-between p-6 md:p-8',
      imageLeft ? 'md:order-2' : 'md:order-1',
    ]}
  >
    <div>
      {/* Eyebrow */}
      <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-white/30 mb-3">
        Featured · {String(featuredIndex + 1).padStart(2, '0')}
      </p>

      {/* Title + link icon */}
      <div class="flex items-start justify-between gap-3 mb-3">
        <h3 class="text-white font-bold text-xl md:text-2xl leading-snug">
          {title}
        </h3>

        {primaryLink && (
          <a
            href={primaryLink}
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 text-white/30 hover:text-white transition-colors duration-200 mt-1"
            aria-label={`Open ${title}`}
          >
            <svg width="16" height="16" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path d="M3 12L12 3M12 3H6.5M12 3V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>

      {/* Description */}
      <p class="text-muted text-sm  leading-relaxed line-clamp-4">
        {description}
      </p>
    </div>

    {/* Bottom: tags + secondary link */}
    <div class="mt-6 flex flex-col gap-4">
      {/* Tags */}
      {technologies.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 list-none" role="list" aria-label="Technologies">
          {technologies.map(tech => (
            <li>
              <span class="inline-block px-2.5 py-[3px] text-[11px] text-white/40 bg-white/[0.04] border border-white/[0.08] rounded-md font-mono">
                {tech}
              </span>
            </li>
          ))}
        </ul>
      )}

      {/* Show both links if available */}
      {(demoUrl || githubUrl) && (
        <div class="flex items-center gap-3 pt-1">
          {demoUrl && (
            // <CtaButton
            //   href={demoUrl}
            //   variant="outline-sm"
            // >
            //   Live demo
            //   <svg width="11" height="11" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            //     <path d="M3 12L12 3M12 3H6.5M12 3V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            //   </svg>
            // </CtaButton>
            <a
              href={demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs font-mono tracking-wider uppercase text-white/60 hover:text-white border border-white/10 hover:border-white/30 px-3 py-1.5 rounded transition-colors duration-200"
              aria-label={`Visit ${title} live site`}
            >
              Live demo
              <svg width="11" height="11" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <path d="M3 12L12 3M12 3H6.5M12 3V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
          {githubUrl && (
            // <CtaButton 
            //   href={githubUrl}
            //   variant="text"
            // >
            //   Source
            //   <GithubIcon class:list='size-4' />
            // </CtaButton>
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs font-mono tracking-wider uppercase text-white/40 hover:text-white/70 transition-colors duration-200"
              aria-label={`View ${title} source code`}
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              Source
            </a>
          )}
        </div>
      )}
    </div>
  </div>

</article>
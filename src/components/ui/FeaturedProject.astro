---
import type { CollectionEntry } from 'astro:content';
import StatusPill from './StatusPill.astro';
import Badge from './Badge.astro';
import CtaButton from './CtaButton.astro';
import GithubIcon from '../icons/tecnologies/GithubIcon.astro';
import { ExternalLinkIcon, InternalLinkIcon } from '../icons/contact';

interface Props {
  project:        CollectionEntry<'projects'>;
  featuredIndex:  number;  // Index within featured array only — drives alternation
}

const { project, featuredIndex } = Astro.props;
const { slug } = project
const { title, description, image, technologies, demoUrl, githubUrl, type } = project.data;

const imageLeft = featuredIndex % 2 === 0;

const PLACEHOLDER = `https://placehold.co/960x600/1a1a1a/444?text=${encodeURIComponent(title)}`;
const primaryLink = demoUrl ?? githubUrl;
---


<article
  class="group relative bg-surface grid grid-cols-1 md:grid-cols-2 rounded-xl overflow-hidden border border-white/6 hover:border-lime/20 transition-colors duration-300"
  aria-label={`Featured project: ${title}`}
>
  {/* Overlay link cubre toda la card */}
  <a
    href={`/project/${slug}`}
    class="card-overlay absolute inset-0 z-[1] rounded-xl"
    aria-label={`Ver detalles de ${title}`}
  />
  <figure
    class:list={[
      'relative overflow-hidden bg-black aspect-16/10 md:aspect-auto',
      // Mobile: always rendered first in DOM → visually on top
      'order-first',
      // Desktop: flip position based on index
      imageLeft ? 'md:order-1' : 'md:order-2',
    ]}
  >
    <img
      src={image ?? PLACEHOLDER}
      alt={`Screenshot of ${title}`}
      class="w-full h-full object-cover object-top-left transition-transform duration-700 group-hover:scale-[1.04]"
      loading="lazy"
      decoding="async"
      width="960"
      height="600"
     transition:name={`project-${slug}`}
    />

    {type && (    
      <span
        class="absolute top-3 hidden left-3 font-mono text-[10px] tracking-widest uppercase px-2 py-1 rounded bg-black/70 backdrop-blur-sm text-white/60 border border-white/10"
        aria-label={`Type: ${type}`}
      >
        {type}
      </span>
    )}
  </figure>

  <section
    class:list={[
      'flex flex-col relative justify-between p-6 md:p-8',
      imageLeft ? 'md:order-2' : 'md:order-1',
    ]}
  >
    <!-- <div class="card-glow"></div> -->
    <article>
      <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-lime mb-3">
        Featured · {String(featuredIndex + 1).padStart(2, '0')}
      </p>
      <div class="flex items-center justify-between gap-3 mb-3">
        <h3 class="text-ink font-bold text-xl md:text-2xl leading-snug">
          {title}
        </h3>
        <CtaButton href={`/project/${slug}`} variant='text'>
          <InternalLinkIcon class:list='stroke-faint group-hover:stroke-muted hover:stroke-lime transition-colors' />
        </CtaButton>
      </div>
      <p class="text-muted text-sm  leading-relaxed line-clamp-4">
        {description}
      </p>
    </article>

    <article class="mt-6 flex flex-col gap-4">
      {technologies.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 list-none" role="list" aria-label="Technologies">
          {technologies.map(tech => (
            <li>
              <Badge 
                className='group-hover:border-lime/12 group-hover:text-lime'
                size="md"
                label={tech}
              />
            </li>
          ))}
        </ul>
      )}

      {(demoUrl || githubUrl) && (
        <div class="flex items-center gap-3 pt-1">
          {demoUrl && (
            <CtaButton
              href={demoUrl}
              variant="outline-sm"
              className='text-sm'
              target='_blank'
            >
              <ExternalLinkIcon class:list="size-3.5 stroke-2"/>
              Demo
            </CtaButton>
          )}
          {githubUrl && (
            <CtaButton 
              href={githubUrl}
              variant="ghost"
              className='px-3 py-1.5 font-mono rounded-md'
            >
              <GithubIcon class:list='size-3.5 ' />
              Source
            </CtaButton>
          )}
        </div>
      )}
    </article>
  </section>

</article>

---
interface Props {
  activeSection?: "experience" | "projects" | "about" | "";
}
const { activeSection = "" } = Astro.props;
---

<header
  class="fixed top-0 inset-x-0 z-50 border-b border-line"
  style="background:rgba(10,10,10,0.85);backdrop-filter:blur(16px)"
>
  <nav class="max-w-4xl mx-auto px-8 h-14 flex items-center justify-between">
    <a
      href="/#home"
      class="font-mono text-sm font-medium tracking-widest text-muted"
    >
      chencho<span class="text-lime">34</span>
    </a>

    <ul class="hidden sm:flex gap-8 list-none items-center">
      <li>
        <a
          href="/#experience"
          class=`text-sm transition-colors ${activeSection === 'experience' ? 'text-lime' : 'text-muted hover:text-ink'}`
        >
          Experiencia
        </a>
      </li>
      <li>
        <a
          href="/#projects"
          class=`text-sm transition-colors ${activeSection === 'projects' ? 'text-lime' : 'text-muted hover:text-ink'}`
        >
          Proyectos
        </a>
      </li>
      <li>
        <a
          href="/#about"
          class=`text-sm transition-colors ${activeSection === 'about' ? 'text-lime' : 'text-muted hover:text-ink'}`
        >
          Sobre mí
        </a>
      </li>
      <li>
        <a
          href="mailto:armandocrescencio343@gmail.com"
          class="font-mono text-xs border border-lime text-lime px-3 py-1.5 rounded-md hover:bg-lime hover:text-base transition-all tracking-wider"
        >
          Contacto
        </a>
      </li>
    </ul>
  </nav>
</header>

---
import Badge from './Badge.astro'
import { techComponents } from '../../constants/icons'
import { ExternalLink } from '../icons/contact'

interface Props {
  title: string
  description: string
  image: string
  href: string
  technologies: string[]
  featured?: boolean    // col-span-2 layout
  type?: 'frontend' | 'backend'
  slug: string
}
const { title, description, image, href, technologies, featured = false, type, slug } = Astro.props
---

<a href={`/project/${slug}`}
   class=`group block bg-surface rounded-xl overflow-hidden border border-line
          hover:border-line2 transition-all duration-300
          ${featured ? 'sm:col-span-2' : ''}`>

  <div class=`${featured ? 'sm:grid sm:grid-cols-[1.2fr_1fr]' : ''}`>

    <!-- image -->
    <div class="overflow-hidden aspect-video bg-surface2">
      <img  transition:name={`project-${slug}`} src={image} alt={title}
           class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"/>
    </div>

    <!-- body -->
    <div class=`p-5 ${featured ? 'flex flex-col justify-between' : ''}`>
      {featured && type && (
        <span class="font-mono text-xs text-lime border border-lime/25 bg-lime/10 px-2.5 py-1 rounded-full mb-3 inline-block">
          {type === 'backend' ? 'Backend' : 'Proyecto destacado'}
        </span>
      )}

      <h3 class="flex justify-between font-semibold text-sm text-ink group-hover:text-lime transition-colors mb-2">
          {title}
          <ExternalLink class:list='size-5' />
        </h3>
      <p class="text-xs text-muted font-light leading-relaxed mb-4 line-clamp-2">{description}</p>
      <div class="flex flex-wrap gap-1.5">
        {
          technologies.map(tech => {
            const Icon = techComponents[tech]
            return Icon ? (
              <Badge size="sm" label={tech}>
                {/* <Icon class:list={"size-3"} /> */}
                {/* <Badge label={tech} size="sm" /> */}

              </Badge>
              ) : null 

          })
        }
      </div>
    </div>
  </div>
</a>
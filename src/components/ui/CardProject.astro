---
/**
 * ProjectCard.astro
 * ─────────────────────────────────────────────────────────────
 * Card component for non-featured projects.
 * Matches the screenshot: horizontal layout, image left ~45%,
 * content right ~55%, dark card background, tag pills.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, image, technologies, demoUrl, githubUrl } = project.data;

const PLACEHOLDER = `https://placehold.co/640x400/1a1a1a/444?text=${encodeURIComponent(title)}`;
const linkUrl     = demoUrl ?? githubUrl;
---

<article class="group flex flex-col sm:flex-row gap-0 bg-surface rounded-xl overflow-hidden border border-white/[0.06] hover:border-white/[0.12] transition-colors duration-300">

  {/* ── Image ─────────────────────────────────────────── */}
  <div class="w-full sm:w-[45%] shrink-0 overflow-hidden bg-black">
    <img
      src={image ?? PLACEHOLDER}
      alt={`Screenshot of ${title}`}
      class="w-full h-48 sm:h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
      loading="lazy"
      decoding="async"
      width="640"
      height="400"
    />
  </div>

  {/* ── Content ───────────────────────────────────────── */}
  <div class="flex flex-col justify-between p-4 sm:p-5 flex-1 min-w-0">

    {/* Title row */}
    <div>
      <div class="flex items-start justify-between gap-3 mb-2">
        <h3 class="text-white font-semibold text-base leading-snug">
          {title}
        </h3>

        {linkUrl && (
          <a
            href={linkUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 text-white/40 hover:text-white transition-colors duration-200 mt-0.5"
            aria-label={`Open ${title}`}
          >
            {/* External link icon — matches the ↗ in screenshot */}
            <svg
              width="15"
              height="15"
              viewBox="0 0 15 15"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 12L12 3M12 3H6.5M12 3V8.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        )}
      </div>

      {/* Description — 3-line clamp matching screenshot */}
      <p class="text-white/50 text-sm leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    {/* Tags */}
    {technologies.length > 0 && (
      <ul
        class="flex flex-wrap gap-1.5 mt-4 list-none"
        role="list"
        aria-label="Technologies"
      >
        {technologies.map(tech => (
          <li>
            <span class="inline-block px-2.5 py-[3px] text-[11px] text-white/40 bg-white/[0.04] border border-white/[0.08] rounded-md font-mono">
              {tech}
            </span>
          </li>
        ))}
      </ul>
    )}
  </div>
</article>
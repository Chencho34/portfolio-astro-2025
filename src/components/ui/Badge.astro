---
import { twMerge } from 'tailwind-merge'

interface Props {
  className?: string
  label?: string
  size?: 'sm' | 'md'   // sm = cards, md = hero/about
}
const { label, size = 'md', className } = Astro.props

const styles = {
  md: "px-2.5 py-1 text-muted hover:border-lime hover:text-lime",
  sm: "px-2 py-0.5 text-faint bg-surface2",
}
---

<span class={twMerge(`font-mono text-xs rounded border border-line2 transition-colors cursor-default ${styles[size]}`, className)}>
  <slot />
  {label}
</span>
